# ===========================================================================
# 模型配置 (Model Configuration)
# ---------------------------------------------------------------------------
# 通过 MODEL_PROVIDER 选择模型供应商，MODEL_NAME 指定具体模型名称。
# 然后填写对应供应商的 API Key（及可能需要的 API URL）即可。
#
# 支持的 MODEL_PROVIDER:
#   google      — Google Gemini，直接使用模型名，需要 GOOGLE_API_KEY
#   claude       — Anthropic Claude，需要 CLAUDE_API_KEY
#   openai       — OpenAI，需要 OPENAI_API_KEY
#   deepseek     — DeepSeek，需要 DEEPSEEK_API_KEY
#   ali          — 阿里百炼(DashScope)，需要 ALI_API_KEY
#   silicon      — 硅基流动(SiliconFlow)，需要 SILICON_API_KEY
#   modelscope   — 魔搭(ModelScope)，需要 MODELSCOPE_API_KEY
#   doubao       — 火山引擎豆包(Doubao/Ark)，需要 DOUBAO_API_KEY
#   vllm         — 自建 vLLM 服务，需要 VLLM_API_KEY + VLLM_API_URL
#   ollama       — 本地 Ollama 服务，需要 OLLAMA_API_KEY + OLLAMA_API_URL
#   local        — 本地兼容 OpenAI 接口(localhost:6688)，需要 ALI_API_KEY
# ===========================================================================

# 当前使用的供应商与模型
MODEL_PROVIDER=deepseek
MODEL_NAME=deepseek-chat

# ---------------------------------------------------------------------------
# 各供应商 API Key（按需填写所选 MODEL_PROVIDER 对应的那一个即可）
# ---------------------------------------------------------------------------
# Google Gemini，例如 MODEL_NAME=gemini-2.5-pro
GOOGLE_API_KEY=

# Anthropic Claude，例如 MODEL_NAME=claude-sonnet-4-5
CLAUDE_API_KEY=

# OpenAI，例如 MODEL_NAME=gpt-4o
OPENAI_API_KEY=

# DeepSeek，例如 MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=your-key-here

# 阿里百炼 DashScope，例如 MODEL_NAME=qwen-max
ALI_API_KEY=

# 硅基流动 SiliconFlow，例如 MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
SILICON_API_KEY=

# 魔搭 ModelScope，例如 MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
MODELSCOPE_API_KEY=

# 火山引擎豆包 Doubao/Ark，MODEL_NAME 填写接入点 ID(ep-xxxx)
DOUBAO_API_KEY=

# 自建 vLLM 服务
VLLM_API_KEY=
VLLM_API_URL=

# 本地 Ollama 服务
OLLAMA_API_KEY=
OLLAMA_API_URL=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# SSE 响应缓存（缓存位置：backend/cache/）
# ---------------------------------------------------------------------------
# 是否启用缓存：true/1/yes/on 启用，false/0/no/off 关闭（默认启用）
SSE_CACHE_ENABLED=true
# 最大缓存条目数（默认 500）
SSE_CACHE_MAX_SIZE=500
# 缓存有效期，单位秒（默认 86400 = 24 小时）
SSE_CACHE_TTL=86400
